`timescale 1ns/1ps
//============================================================
// Module Name : risc_top_tb
// Description : Testbench for 16-bit Single Cycle RISC Processor
//============================================================

module risc_top_tb;

//------------------------------------------------------------
// Testbench Signals
//------------------------------------------------------------

reg clk;
reg rst;

//------------------------------------------------------------
// Instantiate DUT (Device Under Test)
//------------------------------------------------------------

risc_top DUT(

    .clk(clk),
    .rst(rst)

);

//------------------------------------------------------------
// Clock Generation (10 ns Period)
//------------------------------------------------------------

initial
begin
    clk = 1'b0;

    forever #5 clk = ~clk;
end

//------------------------------------------------------------
// Reset Generation
//------------------------------------------------------------

initial
begin

    rst = 1'b1;

    #20;

    rst = 1'b0;

end

//------------------------------------------------------------
// Waveform Dump
//------------------------------------------------------------

initial
begin

    $dumpfile("risc_top.vcd");
    $dumpvars(0,risc_top_tb);

end

//------------------------------------------------------------
// Monitor Processor Operation
//------------------------------------------------------------

initial
begin
    $display("============================================================");
    $display("Time  PC  Instr  Opcode  Result");
    $display("============================================================");

    $monitor("%0t   %h   %h     %h      %h",
              $time,
              DUT.pc,
              DUT.instruction,
              DUT.opcode,
              DUT.alu_result);
end

//------------------------------------------------------------
// Simulation End
//------------------------------------------------------------

initial begin


    wait(DUT.pc == 16'd16);

    #20;

    $display("===========================================");
    $display("Program Execution Completed Successfully");
    $display("===========================================");
    
    $finish;

end

endmodule
