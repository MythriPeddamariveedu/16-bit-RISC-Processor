`timescale 1ns/1ps
//============================================================
// Module Name : sign_extend
// Description : 4-bit to 16-bit Sign Extension
//============================================================

module sign_extend(

    input  wire [3:0] imm_in,

    output wire [15:0] imm_out

);

assign imm_out = {{12{imm_in[3]}}, imm_in};

endmodule
